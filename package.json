{
  "name": "simple-url-shortener-api",
  "version": "0.1.0",
  "private": true,
  "description": "Simple URL shortener API built with Fastify and TypeScript.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.8",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.38.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
